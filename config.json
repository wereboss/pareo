        "Torreents": "/home/sayang/Downloads/Tor/",
        "Ub_Conversion": "/home/sayang/Videos/temp/",
        "Ub_Downloads": "/home/sayang/Downloads/"
    },
    "remote_servers": {
        "Macmini": {
            "user": "sayang",
            "host": "192.168.0.112",
            "key_path": "/home/sayang/.ssh/macmini",
            "bookmarks": {
                "MM_Downloads": "/Users/sri/Downloads/",
                "MM_Eng)Movies": "/Volumes/Server HDD2/VidsMini/Movies/English/",
                "MM_Series": "/Volumes/Server HDD2/VidsMini/Series/",
                "MM_Documentaries": "/Volumes/Server HDD2/VidsMini/Docus/",
                "HDD_Movies": "/Volumes/SRIPASS/Sri/Vids/Movies/English/LiveAction/",
                "HDD_Series": "/Volumes/SRIPASS/Sri/Vids/Series/"
            }
        }
    },
    "generic_cards": {
        "Torrent Downloader": {
            "task_type": "network",
            "command_template": "aria2c --conf-path=/home/sayang/.aria2/aria2.conf --bt-tracker='$(curl -Ns https://githubusercontent.com | awk NF | paste -sd, -)' '{url}' -d '{save_path}'",
            "inputs": [
                { "id": "url", "label": "Torrent URL or Magnet Link", "type": "text" },
                { "id": "save_path", "label": "Save Directory", "type": "directory" }
            ]
        }
    },    
    "switchboard": {
        "Network": {
            "VPN Status": "expressvpn status",
            "VPN ON": "expressvpn connect 'United Kingdom'",
            "VPN OFF": "expressvpn disconnect",
            "VPN KILL": "expressvpn disconnect; pkill -f mount_qbitt; echo \"Killed QBittorren\""
        },        
        "Diagnostics": {
            "Check Uptime": "uptime -p",
            "Disk Space": "df -h / | tail -1 | awk '{print $5}'",
            "Ping Router": "ping -c 3 192.168.1.1"
        }
    },    
    "ffmpeg": {
        "profiles": {
            "To HEVC AAC": {
                "modes": ["single", "batch"],
                "flags": "-c:v libx265 -crf 28 -c:a aac -b:a 128k",
                "allowed_extensions": [".mp4", ".mkv"]
            },
            "To HEVC MP3": {
                "modes": ["single", "batch"],
                "flags": "-c:v libx265 -crf 28 -preset fast -c:a libmp3lame -b:a 128k",
                "allowed_extensions": [".mp4", ".mkv"]
            },
            "To 480p HEVC": {
                "modes": ["single", "batch"],
                "flags": "-vf scale=-2:480 -c:v libx265 -crf 28 -c:a copy",
                "allowed_extensions": [".mp4", ".mkv"]
            },
            "To 720p HEVC": {
                "modes": ["single", "batch"],
                "flags": "-vf scale=-2:720 -c:v libx265 -tag:v hvc1 -crf 28 -c:a copy",
                "allowed_extensions": [".mp4", ".mkv"]
            },
            "To 4x Audio Boost": {
                "modes": ["single", "batch"],
                "flags": "-af \"volume=4\" -c:v copy",
                "allowed_extensions": [".mp4", ".mkv", ".avi"]
            },
            "Extract Audio to MP3": {
                "modes": ["batch"],
                "flags": "-q:a 0 -map a",
                "allowed_extensions": [".mp3"]
            },
            "Extract Subtitles to SRT": {
                "modes": ["single", "batch"],
                "flags": "-map 0:s:0",
                "allowed_extensions": [".srt"]
            }
        }
    },
    "file_operations": {
        "actions": {
            "Copy": {
                "command_template": "cp -r \"{source}\" \"{dest}\"",
                "requires_destination": true,
                "requires_remote": false
            },
            "Move": {
                "command_template": "mv \"{source}\" \"{dest}\"",
                "requires_destination": true,
                "requires_remote": false
            },
            "Delete": {
                "command_template": "rm -rf \"{source}\"",
                "requires_destination": false,
                "requires_remote": false
            },
            "Compress (Tar.gz)": {
                "command_template": "tar -czvf \"{source}.tar.gz\" \"{source}\"",
                "requires_destination": false,
                "requires_remote": false
            },
            "Remote Copy (SCP)": {
                "command_template": "scp -i \"{key_path}\" -r \"{source}\" {user}@{host}:\"{dest}\"",
                "requires_destination": true,
                "requires_remote": true
            },
            "Remote Move (SCP)": {
                "command_template": "scp -i \"{key_path}\" -r \"{source}\" {user}@{host}:\"{dest}\" && rm -rf \"{source}\"",
                "requires_destination": true,
                "requires_remote": true
            }
        }
    },
    "process_monitors": {
        "Numera Engine": {
            "command": "./run.sh",
            "port": 9025,
            "cwd": "/home/sayang/Programs/numera",
            "log_file": "logs/numera.log"
        },
        "Stelata Engine": {
            "command": "./run.sh",
            "port": 9027,
            "cwd": "/home/sayang/Programs/stelata",
            "log_file": "logs/stelata.log"
        },
        "Papyro Engine": {
            "command": "./run.sh",
            "port": 9028,
            "cwd": "/home/sayang/Programs/papyro",
            "log_file": "logs/papyro.log"
        }
    },
    "queue_settings": {
        "concurrency": {
            "media": 1,
            "network": 2,
            "fs": 2,
            "default": 1
        }
    }
}
